# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Serper.dev API Key (replaces SerpAPI)
SERPER_API_KEY=your_serper_api_key_here

# Hunter.io API Key
HUNTER_API_KEY=your_hunter_api_key_here

# Gmail SMTP Configuration
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
SENDER_EMAIL=your-email@gmail.com
SENDER_EMAIL_APP_PASSWORD=your-app-password-here

# Neon DB (PostgreSQL serverless)
# Go to neon.tech → create project → copy connection strings
# DATABASE_URL = pooled connection string (for app queries)
# DIRECT_URL = direct connection string (for prisma migrations)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT Secret (generate a random string)
JWT_SECRET=your_jwt_secret_here
